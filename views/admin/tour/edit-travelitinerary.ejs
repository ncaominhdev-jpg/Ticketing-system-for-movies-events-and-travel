<main class="container mt-5">
    <div class="card shadow-lg p-4">
        <div class="text-center mb-4">
            <h1 class="fw-bold text-primary">Cập nhật Lịch Trình</h1>
            <h3 class="text-secondary"><%= tour.departure_point %> → <%= tour.destination %></h3>
            <h4 class="text-muted">Ngày: <%= new Date(itinerary.travel_date).toLocaleDateString('vi-VN') %></h4>
        </div>

        <form action="/admin/tour/edit-travelItinerary/<%= itinerary.id %>" method="POST">
            <div class="mb-3">
                <label for="travel_date" class="form-label fw-semibold">Ngày đi</label>
                <input type="date" class="form-control" id="travel_date" name="travel_date"
                    value="<%= itinerary.travel_date %>" readonly>
            </div>

            <div class="mb-3">
                <label for="itinerary" class="form-label fw-semibold">Hành trình</label>
                <textarea class="form-control" id="itinerary" rows="4" name="itinerary"><%= itinerary.itinerary %></textarea>
                <% if (errors && errors.itinerary) { %>
                    <div class="text-danger mt-1">
                        <%= errors.itinerary %>
                    </div>
                <% } %>
            </div>

            <div class="d-flex justify-content-between">
                <a href="/admin/tour/details/<%= tour.id %>" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</main>

<script src="https://cdn.tiny.cloud/1/kopg29qtp7buegn0gvha0kw5x0640kup25llnek9z19c4r4u/tinymce/6/tinymce.min.js"
    referrerpolicy="origin"></script>
<script>
    tinymce.init({
        selector: '#itinerary',
        plugins: 'lists link image code textcolor',
        toolbar: 'undo redo | bold italic underline | fontsize fontfamily fontcolor | alignleft aligncenter alignright | bullist numlist | link image | strikethrough code',
        menubar: false,
        branding: false
    });
</script>