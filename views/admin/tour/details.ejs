<main class="container my-5">
    <!-- Thông tin chi tiết tour -->
    <div class="row">
        <div class="col-md-5">
            <img src="<%= '../../../img/' + tour.image_url %>" class="img-fluid rounded shadow-lg"
                style="object-fit: cover; height: 350px; width: 100%;" alt="<%= tour.name %>">
        </div>
        <div class="col-md-5">
            <h1 class="mb-3 text-primary">Du lịch <%= tour.departure_point %> - <%= tour.destination %>
            </h1>
            <p><strong>📅 Khởi hành:</strong>
                <%= new Date(tour.departure_date).toLocaleDateString('vi-VN') %>
            </p>
            <p><strong>🏁 Kết thúc:</strong>
                <%= new Date(tour.end_date).toLocaleDateString('vi-VN') %>
            </p>
            <p><strong>⏳ Thời gian:</strong>
                <%= totalDays %> ngày <%= totalNights %> đêm
            </p>
            <p><strong>💰 Giá:</strong> <span class="text-danger fw-bold">
                    <%= Number(tour.price).toLocaleString("vi-VN").replace(/,/g, '.' ) %> VNĐ/người
                </span></p>
            <p class="text-muted">
                <%= tour.description %>
            </p>
            <p><strong>🕒 Tạo lúc:</strong>
                <%= new Date(tour.createdAt).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' }) %>
            </p>
            <p><strong>🔄 Cập nhật:</strong>
                <%= new Date(tour.updatedAt).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' }) %>
            </p>

            <!-- Nhóm nút chỉnh sửa và xóa -->
            <div class="btn-group mt-3">
                <a href="/admin/tour/edit/<%= tour.id %>" class="btn btn-secondary">✏ Chỉnh Sửa</a>
                <a href="/tour/buy-tickets/<%= tour.id %>" class="btn btn-danger"
                    onclick="return confirm('Bạn có chắc muốn xóa tour này?');">🗑 Xoá</a>
            </div>
        </div>
    </div>

    <!-- Lịch trình chi tiết -->
    <div class="mt-5">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="text-primary">📍 Lịch Trình Chi Tiết</h2>
            <% if (!isItineraryComplete) { %>
                <a href="/admin/tour/add-travelItinerary/<%= tour.id %>" class="btn btn-success">➕ Tạo lịch trình</a>
                <% } %>
        </div>

        <div class="accordion mt-4" id="itineraryAccordion">
            <% if (travelItinerary && travelItinerary.length> 0) { %>
                <% travelItinerary.forEach((item, index)=> { %>
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="day<%= index + 1 %>Heading">
                            <button class="accordion-button <%= index === 0 ? '' : 'collapsed' %>" type="button"
                                data-bs-toggle="collapse" data-bs-target="#day<%= index + 1 %>Content"
                                aria-expanded="<%= index === 0 ? 'true' : 'false' %>"
                                aria-controls="day<%= index + 1 %>Content">
                                <strong>🗓 Ngày <%= new Date(item.travel_date).toLocaleDateString('vi-VN') %></strong>
                            </button>
                        </h2>
                        <div id="day<%= index + 1 %>Content"
                            class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>"
                            aria-labelledby="day<%= index + 1 %>Heading" data-bs-parent="#itineraryAccordion">
                            <div class="accordion-body">
                                <p><%- item.itinerary %></p>
                                <p class="text-muted small"><strong>⏳ Tạo:</strong>
                                    <%= new Date(item.createdAt).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh'
                                        }) %>
                                </p>
                                <p class="text-muted small"><strong>🔄 Cập nhật:</strong>
                                    <%= new Date(item.updatedAt).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh'
                                        }) %>
                                </p>
                                <div class="mt-3">
                                    <a href="/admin/tour/edit-travelItinerary/<%= item.id %>"
                                        class="btn btn-warning btn-sm">✏ Sửa</a>
                                    <a href="javascript:void(0);" onclick="confirmDeleteItinerary('<%= item.id %>')"
                                        class="btn btn-danger btn-sm">
                                        🗑 Xóa Lịch Trình
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <p class="text-muted">Chưa có lịch trình chi tiết.</p>
                            <% } %>
        </div>
    </div>
</main>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function confirmDeleteItinerary(itineraryId) {
        Swal.fire({
            title: "Bạn có chắc chắn?",
            text: "Hành động này sẽ xóa lịch trình vĩnh viễn!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33",
            cancelButtonColor: "#3085d6",
            confirmButtonText: "Xóa ngay",
            cancelButtonText: "Hủy"
        }).then((result) => {
            if (result.isConfirmed) {
                fetch(`/admin/tour/delete-travelItinerary/${itineraryId}`, {
                    method: "DELETE",
                    headers: { "Content-Type": "application/json" }
                })
                .then(response => response.json()) 
                .then(data => {
                    if (data.error) {
                        Swal.fire("Lỗi!", data.error, "error");
                    } else {
                        Swal.fire("Đã xóa!", data.message, "success")
                            .then(() => window.location.reload()); 
                    }
                })
                .catch(error => {
                    console.error("Lỗi:", error);
                    Swal.fire("Lỗi!", "Có lỗi xảy ra, thử lại sau.", "error");
                });
            }
        });
    }
</script>