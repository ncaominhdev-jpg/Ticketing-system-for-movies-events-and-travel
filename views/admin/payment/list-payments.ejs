<main class="my-4">
    <h1 class="mb-4">Quản Lý Thanh Toán</h1>

    <!-- Tab menu -->
    <ul class="nav nav-tabs" id="paymentTab" role="tablist">
        <li class="nav-item" role="presentation">
            <a class="nav-link active" id="movie-tab" data-bs-toggle="tab" href="#movie" role="tab"
                aria-controls="movie" aria-selected="true">Vé Xem Phim</a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link" id="event-tab" data-bs-toggle="tab" href="#event" role="tab" aria-controls="event"
                aria-selected="false">Vé Sự Kiện</a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link" id="tour-tab" data-bs-toggle="tab" href="#tour" role="tab" aria-controls="tour"
                aria-selected="false">Vé Tour Du Lịch</a>
        </li>
    </ul>

    <div class="tab-content mt-3" id="paymentTabContent">
        <!-- Vé Xem Phim -->
        <div class="tab-pane fade show active" id="movie" role="tabpanel" aria-labelledby="movie-tab">
            <h4 class="mb-4">Danh Sách Vé Xem Phim</h4>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Mã Vé</th>
                        <th>Tên Phim</th>
                        <th>Ngày Chiếu</th>
                        <th>Giá Vé</th>
                        <th>Trạng Thái Thanh Toán</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Dữ liệu vé xem phim -->
                    <tr>
                        <td>#MV001</td>
                        <td><a href="/admin/add-movie-showtime">Phim A</a></td>
                        <td>2025-02-01</td>
                        <td>150,000 VND</td>
                        <td>Chưa Thanh Toán</td>
                        <td><button class="btn btn-success" onclick="showConfirmModal('Phim A', '#MV001')">Xác Nhận</button></td>
                    </tr>
                    <tr>
                        <td>#MV002</td>
                        <td><a href="/admin/add-movie-showtime">Phim B</a></td>
                        <td>2025-02-05</td>
                        <td>180,000 VND</td>
                        <td>Đã Thanh Toán</td>
                        <td><button class="btn btn-info" disabled>Đã Thanh Toán</button></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Vé Sự Kiện -->
        <div class="tab-pane fade" id="event" role="tabpanel" aria-labelledby="event-tab">
            <h4 class="mb-4">Danh Sách Vé Sự Kiện</h4>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Mã Vé</th>
                        <th>Tên Sự Kiện</th>
                        <th>Ngày Sự Kiện</th>
                        <th>Giá Vé</th>
                        <th>Trạng Thái Thanh Toán</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Dữ liệu vé sự kiện -->
                    <tr>
                        <td>#EV001</td>
                        <td><a href="/admin/add-event">Sự Kiện A</a></td>
                        <td>2025-02-10</td>
                        <td>200,000 VND</td>
                        <td>Chưa Thanh Toán</td>
                        <td><button class="btn btn-success" onclick="showConfirmModal('Phim A', '#MV001')">Xác Nhận</button></td>
                    </tr>
                    <tr>
                        <td>#EV002</td>
                        <td><a href="/admin/add-event">Sự Kiện B</a></td>
                        <td>2025-02-15</td>
                        <td>250,000 VND</td>
                        <td>Đã Thanh Toán</td>
                        <td><button class="btn btn-info" disabled>Đã Thanh Toán</button></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Vé Tour Du Lịch -->
        <div class="tab-pane fade" id="tour" role="tabpanel" aria-labelledby="tour-tab">
            <h4 class="mb-4">Danh Sách Vé Tour Du Lịch</h4>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Mã Vé</th>
                        <th>Tên Tour</th>
                        <th>Ngày Khởi Hành</th>
                        <th>Giá Vé</th>
                        <th>Trạng Thái Thanh Toán</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Dữ liệu vé tour du lịch -->
                    <tr>
                        <td>#TO001</td>
                        <td><a href="/admin/add-tour">Tour A</a></td>
                        <td>2025-03-01</td>
                        <td>3,000,000 VND</td>
                        <td>Chưa Thanh Toán</td>
                        <td><button class="btn btn-success" onclick="showConfirmModal('Phim A', '#MV001')">Xác Nhận</button></td>
                    </tr>
                    <tr>
                        <td>#TO002</td>
                        <td><a href="/admin/add-tour">Tour B</a></td>
                        <td>2025-03-10</td>
                        <td>3,500,000 VND</td>
                        <td>Đã Thanh Toán</td>
                        <td><button class="btn btn-info" disabled>Đã Thanh Toán</button></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Toast thông báo -->
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div id="paymentToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <strong class="me-auto">Thông Báo</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">
                Thanh toán thành công cho vé <span id="toast-movie-name"></span> (Mã vé: <span
                    id="toast-ticket-id"></span>).
            </div>
        </div>
    </div>

    <!-- Modal Xác Nhận Thanh Toán -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmModalLabel">Xác Nhận Thanh Toán</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Bạn có chắc chắn muốn thanh toán cho vé <strong id="movie-name"></strong> (Mã vé: <strong
                        id="ticket-id"></strong>)?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary" id="confirm-payment-btn">Xác Nhận</button>
                </div>
            </div>
        </div>
    </div>

</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

<!-- JavaScript Custom -->
<script>
    function showConfirmModal(movieName, ticketId) {
        // Hiển thị thông tin vé và thiết lập các dữ liệu
        document.getElementById('movie-name').textContent = movieName;
        document.getElementById('ticket-id').textContent = ticketId;

        // Hiển thị modal
        const confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
        confirmModal.show();

        // Cập nhật nút Xác Nhận thanh toán
        document.getElementById('confirm-payment-btn').onclick = function () {
            // Hiển thị Toast thông báo
            document.getElementById('toast-movie-name').textContent = movieName;
            document.getElementById('toast-ticket-id').textContent = ticketId;

            // Tạo một Toast và hiển thị
            const toast = new bootstrap.Toast(document.getElementById('paymentToast'));
            toast.show();

            // Đóng modal sau khi xác nhận
            confirmModal.hide();
        };
    }
</script>