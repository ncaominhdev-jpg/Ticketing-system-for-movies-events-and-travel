<main class="container my-5">
    <h1 class="text-center mb-4 text-primary fw-bold">Cập Nhật Phim <%= name ? name : '' %></h1>

    <div class="card shadow p-4">
        <form action="/admin/movie/edit/<%= id %>" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
                <label for="name" class="form-label fw-semibold">Tên Phim</label>
                <input type="text" id="name" name="name" class="form-control" placeholder="Nhập tên phim" value="<%= name ? name : '' %>">
                <% if (errors && errors.name) { %>
                    <div class="text-danger mt-1"><%= errors.name %></div>
                <% } %>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="genre" class="form-label fw-semibold">Thể Loại</label>
                    <input type="text" id="genre" name="genre" class="form-control" placeholder="Hành động, Kinh dị..." value="<%= genre ? genre : '' %>">
                    <% if (errors && errors.genre) { %>
                        <div class="text-danger mt-1"><%= errors.genre %></div>
                    <% } %>
                </div>

                <div class="col-md-6 mb-3">
                    <label for="release-date" class="form-label fw-semibold">Ngày Phát Hành</label>
                    <input type="date" id="release-date" name="release_date" class="form-control" value="<%= release_date ? release_date : '' %>">
                    <% if (errors && errors.release_date) { %>
                        <div class="text-danger mt-1"><%= errors.release_date %></div>
                    <% } %>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="movie-director" class="form-label fw-semibold">Đạo diễn</label>
                    <input type="text" id="movie-director" name="director" class="form-control" value="<%= director ? director : '' %>">
                    <% if (errors && errors.director) { %>
                        <div class="text-danger mt-1"><%= errors.director %></div>
                    <% } %>
                </div>

                <div class="col-md-6 mb-3">
                    <label for="movie-actors" class="form-label fw-semibold">Diễn viên</label>
                    <input type="text" id="movie-actors" name="actors" class="form-control" value="<%= actors ? actors : '' %>">
                    <% if (errors && errors.actors) { %>
                        <div class="text-danger mt-1"><%= errors.actors %></div>
                    <% } %>
                </div>
            </div>

            <div class="mb-3">
                <label for="movie-description" class="form-label fw-semibold">Mô Tả</label>
                <textarea id="movie-description" name="description" class="form-control" rows="4" placeholder="Nhập mô tả phim"><%= description ? description : '' %></textarea>
                <% if (errors && errors.description) { %>
                    <div class="text-danger mt-1"><%= errors.description %></div>
                <% } %>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="movie-poster" class="form-label fw-semibold">Hình Ảnh Poster</label>
                    <input type="file" id="movie-poster" name="poster" class="form-control">
                    <% if (errors && errors.poster) { %>
                        <div class="text-danger mt-1"><%= errors.poster %></div>
                    <% } %>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Hình ảnh hiện tại</label>
                    <div class="border p-2 d-flex justify-content-center">
                        <img src="../../../img/<%= image_url ? image_url : '' %>" alt="Hình ảnh phim" class="img-fluid rounded w-50">
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label for="movie-status" class="form-label fw-semibold">Trạng Thái</label>
                <select id="movie-status" name="status" class="form-select">
                    <option value="1" <%= movie.status == 1 ? 'selected' : '' %>>Hiển thị</option>
                    <option value="2" <%= movie.status == 2 ? 'selected' : '' %>>Ẩn</option>
                </select>
            </div>

            <div class="d-flex justify-content-between">
                <a href="/admin/movie/list" class="btn btn-outline-secondary px-4">Hủy</a>
                <button type="submit" class="btn btn-primary px-4">Cập nhật</button>
            </div>
        </form>
    </div>
</main>

<script src="https://cdn.tiny.cloud/1/kopg29qtp7buegn0gvha0kw5x0640kup25llnek9z19c4r4u/tinymce/6/tinymce.min.js"
    referrerpolicy="origin"></script>