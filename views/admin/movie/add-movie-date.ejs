
<main class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Thêm Ngày Chiếu Phim <%= movie.name %></h3>
                </div>
                <div class="card-body">
                    <!-- Add Movie Date Form -->
                    <form action="/admin/movie/add-date/<%= movie.id %>" method="POST">
                        <div class="mb-3">
                            <label for="date_show" class="form-label fw-semibold">Ngày Chiếu</label>
                            <input type="date" id="date_show" name="date_show" class="form-control form-control-lg">
                            <% if (errors && errors.date_show) { %>
                                <div class="alert alert-danger mt-2">
                                    <%= errors.date_show %>
                                </div>
                            <% } %>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/admin/movie/date/<%= movie.id %>" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Hủy
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-calendar-plus"></i> Thêm Ngày Chiếu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>


<script src="https://cdn.tiny.cloud/1/kopg29qtp7buegn0gvha0kw5x0640kup25llnek9z19c4r4u/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>