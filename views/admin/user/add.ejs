<main class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Thêm Người Dùng</h4>
        </div>

        <div class="card-body">
            <form action="/admin/user/add" method="POST">
                <!-- Họ Tên -->
                <div class="mb-3">
                    <label class="form-label">Họ Tên</label>
                    <input type="text" name="username" class="form-control" value="<%= formData.username || '' %>" placeholder="Nhập họ tên">
                    <span class="text-danger"><%= errors && errors.username? errors.username : '' %></span>
                </div>

                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" value="<%= formData.email || '' %>" placeholder="Nhập email">
                    <span class="text-danger"><%= errors && errors.email? errors.email : '' %></span>
                </div>

                <!-- Mật khẩu -->
                <div class="mb-3">
                    <label class="form-label">Mật khẩu</label>
                    <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu">
                    <span class="text-danger"><%= errors && errors.password? errors.password : '' %></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Nhập lại mật khẩu</label>
                    <input type="password" name="confirm_password" class="form-control" placeholder="Nhập lại mật khẩu">
                    <span class="text-danger"><%= errors && errors["confirm-password"] ? errors["confirm-password"] : '' %></span>
                </div>

                <!-- Vai trò -->
                <div class="mb-3">
                    <label class="form-label">Vai Trò</label>
                    <select name="role" class="form-select">
                        <option value="1" <%= formData.role == 1 ? 'selected' : '' %>>Admin</option>
                        <option value="2" <%= formData.role == 2 ? 'selected' : '' %>>Người dùng</option>
                    </select>
                </div>

                <!-- Trạng thái -->
                <div class="mb-3">
                    <label class="form-label">Trạng Thái</label>
                    <select name="status" class="form-select">
                        <option value="1" <%= formData.status == 1 ? 'selected' : '' %>>Hoạt Động</option>
                        <option value="2" <%= formData.status == 2 ? 'selected' : '' %>>Tạm Ngừng</option>
                    </select>
                </div>

                <!-- Nút Submit -->
                <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Lưu</button>
                <a href="/admin/user/list" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay Lại</a>
            </form>
        </div>
    </div>
</main>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
