<main class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary fw-bold">🎵 Quản Lý Concert</h1>
    </div>

    <!-- Danh sách Concert -->
    <div class="card shadow-lg rounded-3 border-0">
        <div class="card-body">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark text-center">
                    <tr>
                        <th>#</th>
                        <th>Tên Concert</th>
                        <th>Ngày & Giờ</th>
                        <th>Địa Điểm</th>
                        <th>Trạng Thái</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (concerts.length > 0) { %>
                        <% concerts.forEach((concert, index) => { %>
                            <tr class="fw-semibold">
                                <td class="text-center"><%= index + 1 %></td>
                                <td>
                                    <a href="/admin/concert/details/<%= concert.id %>" 
                                       class="text-decoration-none fw-bold text-primary"
                                       title="<%= concert.name %>">
                                        <i class="bi bi-music-note-beamed me-2"></i>
                                        <%= concert.name.length > 25 ? concert.name.substring(0, 25) + "..." : concert.name %>
                                    </a>
                                </td>                                
                                <td class="text-center">
                                    <i class="bi bi-calendar-event me-2"></i>
                                    <%= new Date(concert.event_date).toLocaleDateString("vi-VN") %> 
                                    <br>
                                    <i class="bi bi-clock me-2"></i> <%= concert.start_time %>
                                </td>
                                <td class="text-center">
                                    <i class="bi bi-geo-alt me-2"></i> 
                                    <span class="location-text" title="<%= concert.location %>">
                                        <%= concert.location.length > 15 ? concert.location.substring(0, 15) + "..." : concert.location %>
                                    </span>
                                </td>                                

                                <% let today = new Date(); today.setHours(0, 0, 0, 0);
                                   let concertDate = new Date(concert.event_date); %>
                                <td class="text-center">
                                    <% if (concertDate > today) { %>
                                        <span class="badge bg-warning px-3 py-2 fs-6">Sắp diễn ra</span>
                                    <% } else if (concertDate.getTime() === today.getTime()) { %>
                                        <span class="badge bg-success px-3 py-2 fs-6">Đang diễn ra</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary px-3 py-2 fs-6">Đã kết thúc</span>
                                    <% } %>
                                </td>

                                <td class="text-center">
                                    <a href="/admin/concert/edit/<%= concert.id %>" 
                                       class="btn btn-warning btn-sm rounded-pill shadow-sm px-3 me-2">
                                        <i class="bi bi-pencil-square"></i> Chỉnh sửa
                                    </a>
                                    <a href="/admin/delete-concert/<%= concert.id %>" 
                                       class="btn btn-danger btn-sm rounded-pill shadow-sm px-3">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center text-muted fs-5">📭 Không có concert nào</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>
