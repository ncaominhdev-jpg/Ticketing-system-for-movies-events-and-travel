<main class="container my-5">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white text-center">
            <h3 class="mb-0">Chỉnh Sửa Nghệ Sĩ Concert <%= concert.name %></h3>
        </div>
        <div class="card-body">
            <form action="/admin/concert/edit-artist/<%= artist.id %>" method="POST" enctype="multipart/form-data">
                <div class="mb-3 form-floating">
                    <input type="text" class="form-control" id="artist_name" name="artist_name"
                        value="<%= artist.artist_name %>" placeholder="Tên Nghệ Sĩ">
                    <label for="artist_name">Tên Nghệ Sĩ</label>
                    <div class="text-danger">
                        <% if (errors && errors.artist_name) { %>
                            <%= errors.artist_name %>
                        <% } %>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label fw-bold">Hình Ảnh Nghệ Sĩ</label>
                    <input type="file" class="form-control" id="image" name="image">
                    <small class="text-muted d-block mt-1">Để trống nếu không muốn thay đổi hình ảnh.</small>
                    <div class="text-danger">
                        <% if (errors && errors.image) { %>
                            <%= errors.image %>
                        <% } %>
                    </div>
                </div>

                <div class="text-center my-4">
                    <div class="card border-0 shadow-sm d-inline-block p-3" style="max-width: 400px;">
                        <img src="/img/<%= artist.image_url ? artist.image_url : 'default-artist.jpg' %>"
                            alt="<%= artist.artist_name %>"
                            class="img-fluid rounded-circle border border-3 border-primary shadow-lg"
                            width="400"
                            style="transition: all 0.3s ease-in-out;">
                    </div>
                </div>
                

                <div class="d-flex justify-content-between">
                    <a href="/admin/concert/details/<%= concert.id %>" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Hủy
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Cập Nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>
