<main class="container my-4">
    <div class="card shadow p-4 rounded">
        <h1 class="text-center mb-4 text-primary fw-bold">
            <i class="bi bi-mic"></i> Thêm Ca Sĩ - <%= concert.name %>
        </h1>

        <form action="/admin/concert/add-artist/<%= concert.id %>" method="POST" enctype="multipart/form-data">
            <!-- Tên Ca Sĩ -->
            <div class="mb-3">
                <label for="artist_name" class="form-label fw-bold">Tên Ca Sĩ</label>
                <input type="text" id="artist_name" name="artist_name" class="form-control" placeholder="Nhập tên ca sĩ...">
                <% if (errors && errors.artist_name) { %>
                    <div class="text-danger mt-1"><%= errors.artist_name %></div>
                <% } %>
            </div>

            <!-- Hình Ảnh -->
            <div class="mb-3">
                <label for="image_url" class="form-label fw-bold">Hình Ảnh</label>
                <input type="file" id="image_url" name="image_url" class="form-control" accept="image/*" onchange="previewImage(event)">
                
                <% if (errors && errors.image_url) { %>
                    <div class="text-danger mt-1"><%= errors.image_url %></div>
                <% } %>

                <!-- Hiển thị ảnh preview -->
                <div class="text-center mt-3">
                    <img id="preview" src="#" class="img-thumbnail w-25 d-none" alt="Hình ảnh ca sĩ">
                </div>
            </div>

            <!-- Nút điều hướng -->
            <div class="text-center">
                <a href="/admin/movie/showtime/<%= concert.id %>" class="btn btn-secondary">
                    <i class="bi bi-arrow-left-circle"></i> Hủy
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-person-plus"></i> Thêm Ca Sĩ
                </button>
            </div>
        </form>
    </div>
</main>

<!-- Thêm Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

<!-- Script xem trước ảnh -->
<script>
    function previewImage(event) {
        const preview = document.getElementById('preview');
        const file = event.target.files[0];

        if (file) {
            preview.src = URL.createObjectURL(file);
            preview.classList.remove('d-none');
        } else {
            preview.classList.add('d-none');
        }
    }
</script>
