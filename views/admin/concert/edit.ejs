<main class="container my-5">
    <div class="card shadow p-4 rounded">
        <h1 class="text-center mb-4 text-primary fw-bold">
            <i class="bi bi-music-note"></i> Cập Nhật Sự Kiện - <%= concert.name %>
        </h1>

        <form action="/admin/concert/edit/<%= concert.id %>" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
                <label for="name" class="form-label fw-bold">Tên sự kiện</label>
                <input type="text" id="name" name="name" class="form-control" value="<%= concert.name %>">
                <span class="text-danger">
                    <% if (errors && errors.name) { %>
                        <%= errors.name %>
                    <% } %>
                </span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="event_date" class="form-label fw-bold">Ngày diễn ra</label>
                    <input type="date" id="event_date" name="event_date" class="form-control" value="<%= concert.event_date %>">
                    <span class="text-danger">
                        <% if (errors && errors.event_date) { %>
                            <%= errors.event_date %>
                        <% } %>
                    </span>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="start_time" class="form-label fw-bold">Giờ bắt đầu</label>
                    <input type="time" id="start_time" name="start_time" class="form-control" value="<%= concert.start_time %>">
                    <span class="text-danger">
                        <% if (errors && errors.start_time) { %>
                            <%= errors.start_time %>
                        <% } %>
                </div>
            </div>

            <div class="mb-3">
                <label for="location" class="form-label fw-bold">Địa điểm</label>
                <input type="text" id="location" name="location" class="form-control" value="<%= concert.location %>">
                <span class="text-danger">
                    <% if (errors && errors.location) { %>
                        <%= errors.location %>
                    <% } %>
                </span>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label fw-bold">Mô tả</label>
                <textarea id="description" name="description" class="form-control" rows="3"><%= concert.description %></textarea>
                <span class="text-danger">
                    <% if (errors && errors.description) { %>
                        <%= errors.description %>
                    <% } %>
                </span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="vip_price" class="form-label fw-bold">Giá VIP</label>
                    <input type="number" id="vip_price" name="vip_price" class="form-control" value="<%= concert.vip_price %>">
                    <span class="text-danger">
                        <% if (errors && errors.vip_price) { %>
                            <%= errors.vip_price %>
                        <% } %>
                    </span>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="normal_price" class="form-label fw-bold">Giá Thường</label>
                    <input type="number" id="normal_price" name="normal_price" class="form-control" value="<%= concert.normal_price %>">
                    <span class="text-danger">
                        <% if (errors && errors.normal_price) { %>
                            <%= errors.normal_price %>
                        <% } %>
                    </span>
                </div>
            </div>

            <div class="mb-3">
                <label for="poster" class="form-label fw-bold">Hình ảnh</label>
                <input type="file" id="poster" name="poster" accept="image/*" class="form-control">
                <span>
                    <% if (errors && errors.poster) { %>
                        <div class="text-danger mt-1"><%= errors.poster %></div>
                    <% } %>
                </span>
                
                <% if (concert.image_url) { %>
                    <div class="mt-3 text-center">
                        <img src="../../../img/<%= concert.image_url %>" alt="Hình ảnh sự kiện" class="img-thumbnail w-25">
                    </div>
                <% } %>
            </div>

            <div class="text-center">
                <a href="/admin/concert/details/<%= concert.id %>" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Hủy
                </a>
                <button type="submit" class="btn btn-primary fw-bold">
                    <i class="bi bi-check-circle"></i> Cập nhật ngay
                </button>
            </div>
        </form>
    </div>
</main>

<!-- Thêm Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
