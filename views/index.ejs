<head>
    <link rel="stylesheet" href="./css/styles-index.css">
</head>
<!-- Carousel -->
<div id="mainCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="../img/xem-phim-rap.jpg" class="d-block w-100" alt="Phim">
            <div class="carousel-caption d-none d-md-block">
                <h5>Đặt vé xem phim nhanh chóng</h5>
                <p>Thưởng thức những bộ phim hay nhất.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="../img/concert.jpg" class="d-block w-100" alt="Sự kiện">
            <div class="carousel-caption d-none d-md-block">
                <h5>Sự kiện nổi bật</h5>
                <p>Không bỏ lỡ các sự kiện hấp dẫn.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="../img/nha-trang.jpg" class="d-block w-100" alt="Du lịch">
            <div class="carousel-caption d-none d-md-block">
                <h5>Đặt tour du lịch dễ dàng</h5>
                <p>Khám phá những điểm đến lý tưởng.</p>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>
<main class="container my-5">
    <!-- Movies Section -->
    <div id="movies" class="mb-5">
        <h2 class="text-center">Xem Phim</h2>
        <p class="text-center">Đặt vé xem phim với nhiều lựa chọn phong phú.</p>
        <div class="row">
            <% movies.slice(0, 4).forEach(movie=> { %>
                <div class="col-md-3">
                    <a href="/movie/details/<%= movie.id %>" class="text-decoration-none text-dark">
                        <div class="card">
                            <!-- Hình ảnh với chiều cao cố định -->
                            <img src="<%= './img/' + movie.image_url %>" class="card-img-top" alt="<%= movie.name %>">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%= movie.name.length> 25 ? movie.name.substring(0, 20) + "..." : movie.name %>
                                </h5>
                                <p class="card-text"><strong>Thể loại:</strong>
                                    <%= movie.genre.length> 20 ? movie.genre.substring(0, 20) + "..." : movie.genre %>
                                </p>
                                <p class="card-text"><strong>Đạo diễn:</strong>
                                    <%= movie.director %>
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
                <% }); %>
        </div>

        <% if (movies.length> 4) { %>
            <div class="text-center mt-3">
                <a href="/movie/list" class="btn btn-secondary">Xem thêm</a>
            </div>
            <% } %>
    </div>

    <!-- Concerts Section -->
    <div id="events" class="mb-5">
        <h2 class="text-center">Sự Kiện</h2>
        <p class="text-center">Tham gia các sự kiện hấp dẫn.</p>
        <div class="row">
            <% concerts.slice(0, 4).forEach(concert=> {
                const eventDate = new Date(concert.event_date);
                %>
                <div class="col-md-3">
                    <a href="/concert/details/<%= concert.id %>" class="text-decoration-none text-dark">
                        <div class="card">
                            <img src="<%= './img/' + concert.image_url %>" class="card-img-top"
                                alt="<%= concert.name %>">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%= concert.name %>
                                </h5>
                                <p class="card-text"><strong>Thời gian:</strong>
                                    <%= eventDate.toLocaleDateString("vi-VN") %> - <%= concert.start_time %>
                                </p>
                                <p class="card-text"><strong>Địa điểm:</strong>
                                    <%= concert.location %>
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
                <% }) %>
        </div>
        <% if (concerts.length> 4) { %>
            <div class="text-center mt-3">
                <a href="/concerts" class="btn btn-outline-primary">Xem Thêm</a>
            </div>
            <% } %>
    </div>


    <!-- Tours Section -->
    <div id="tours" class="mb-5">
        <h2 class="text-center">Du Lịch</h2>
        <p class="text-center">Khám phá những điểm đến tuyệt vời.</p>
        <div class="row">
            <% tours.slice(0, 4).forEach(tour=> { %>
                <div class="col-md-3">
                    <a href="/tour/details/<%= tour.id %>" class="text-decoration-none text-dark">
                        <div class="card">
                            <img src="<%= './img/' + tour.image_url %>" class="card-img-top" alt="<%= tour.name %>">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%= tour.departure_point %> - <%= tour.destination %>
                                </h5>
                                <p class="card-text">
                                    <strong>Địa điểm:</strong>
                                    <%= tour.location %><br>
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
                <% }) %>
        </div>
        <% if (tours.length> 4) { %>
            <div class="text-center mt-3">
                <a href="/tours/list" class="btn btn-outline-primary">Xem Thêm</a>
            </div>
            <% } %>
    </div>
</main>