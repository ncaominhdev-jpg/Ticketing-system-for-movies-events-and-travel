<!DOCTYPE html>
<html lang="vi" class="h-100">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title || 'Trang quản trị' %>
    </title>
    <!-- Styles -->
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/admin/styles-dashboard.css">
</head>

<body>
    <div class="admin-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-menu">
                <h4 class="text-white px-4 mb-4 mt-3">Admin Dashboard</h4>
                <nav class="nav flex-column">
                    <!-- Dashboard -->
                    <a class="nav-link sidebar-link" href="/admin">
                        <i class="bi bi-speedometer2"></i>
                        Thống kê
                    </a>

                    <!-- Movie Tickets -->
                    <div class="dropdown-nav">
                        <a class="nav-link sidebar-link dropdown-toggle" data-bs-toggle="collapse" href="#movieMenu">
                            <i class="bi bi-ticket-perforated"></i>
                            Vé Phim
                        </a>
                        <div class="collapse" id="movieMenu">
                            <div class="nav flex-column ms-4">
                                <a class="nav-link sidebar-link" href="/admin/movie/list">Danh sách</a>
                                <a class="nav-link sidebar-link" href="/admin/movie/add">Thêm mới</a>
                            </div>
                        </div>
                    </div>

                    <!-- Concert Tickets -->
                    <div class="dropdown-nav">
                        <a class="nav-link sidebar-link dropdown-toggle" data-bs-toggle="collapse" href="#concertMenu">
                            <i class="bi bi-music-note"></i>
                            Concert & Sự kiện
                        </a>
                        <div class="collapse" id="concertMenu">
                            <div class="nav flex-column ms-4">
                                <a class="nav-link sidebar-link" href="/admin/concert/list">Danh sách</a>
                                <a class="nav-link sidebar-link" href="/admin/concert/add">Thêm mới</a>
                            </div>
                        </div>
                    </div>

                    <!-- Tour Tickets -->
                    <div class="dropdown-nav">
                        <a class="nav-link sidebar-link dropdown-toggle" data-bs-toggle="collapse" href="#tourMenu">
                            <i class="bi bi-globe"></i>
                            Tour du lịch
                        </a>
                        <div class="collapse" id="tourMenu">
                            <div class="nav flex-column ms-4">
                                <a class="nav-link sidebar-link" href="/admin/tour/list">Danh sách</a>
                                <a class="nav-link sidebar-link" href="/admin/tour/add">Thêm mới</a>
                            </div>
                        </div>
                    </div>

                    <!-- User Management -->
                    <div class="dropdown-nav">
                        <a class="nav-link sidebar-link dropdown-toggle" data-bs-toggle="collapse" href="#userMenu">
                            <i class="bi bi-people"></i>
                            Người dùng
                        </a>
                        <div class="collapse" id="userMenu">
                            <div class="nav flex-column ms-4">
                                <a class="nav-link sidebar-link" href="/admin/user/list">Danh sách</a>
                                <a class="nav-link sidebar-link" href="/admin/user/add">Thêm mới</a>
                            </div>
                        </div>
                    </div>

                    <!-- Payments -->
                    <a class="nav-link sidebar-link" href="/admin/list-payments">
                        <i class="bi bi-credit-card"></i>
                        Quản lý thanh toán
                    </a>
                </nav>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Navbar -->
            <nav class="admin-navbar navbar navbar-expand-lg">
                <div class="container-fluid">
                    <button class="btn btn-sm d-lg-none" onclick="toggleSidebar()">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="d-flex align-items-center ms-auto">
                        <div class="dropdown">
                            <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="userMenu"
                                data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Hồ sơ</a></li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li><a class="dropdown-item text-danger" href="#"><i
                                            class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <!-- Content Container -->
            <div class="container-fluid py-4">
                <!-- Page Title -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold text-primary">Trang Quản Trị</h3>
                </div>

                <!-- Dynamic Content -->
                <div class="dashboard-content">
                    <%- body %>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle sidebar trên mobile
        function toggleSidebar() {
            document.querySelector('.sidebar').classList.toggle('active');
        }

        // Đóng dropdown khi click ra ngoài
        document.addEventListener('click', function (event) {
            if (!event.target.closest('.dropdown-nav')) {
                document.querySelectorAll('.collapse').forEach(collapse => {
                    if (collapse.classList.contains('show')) {
                        new bootstrap.Collapse(collapse).hide();
                    }
                });
            }
        });
    </script>
</body>

</html>