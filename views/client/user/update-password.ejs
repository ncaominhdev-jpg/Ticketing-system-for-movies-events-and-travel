<head>
    <link rel="stylesheet" href="../css/styles-layout.css">
</head>
<main>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <!-- Thay Đổi Mật Khẩu -->
            <div class="col-md-6">
                <div class="card shadow-sm p-4">
                    <h2 class="mb-4 text-center text-primary">🔐 Thay Đổi Mật Khẩu</h2>
                    <form action="/update-password" method="POST">
                        <div class="mb-3">
                            <label for="currentPassword" class="form-label">Mật Khẩu Hiện Tại</label>
                            <input type="password" class="form-control" id="currentPassword" name="oldPassword" placeholder="Nhập mật khẩu hiện tại">
                            <span class="text-danger"><%= errors && errors.oldPassword? errors.oldPassword : '' %></span>
                        </div>
                        <div class="mb-3">
                            <label for="newPassword" class="form-label">Mật Khẩu Mới</label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword" placeholder="Nhập mật khẩu mới">
                            <span class="text-danger" ><%= errors && errors.newPassword? errors.newPassword : '' %></span>
                        </div>
                        <div class="mb-3">
                            <label for="confirmPassword" class="form-label">Xác Nhận Mật Khẩu Mới</label>
                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Xác nhận mật khẩu mới">
                            <span class="text-danger""><%= errors && errors.confirmPassword? errors.confirmPassword : '' %></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">🔄 Cập Nhật Mật Khẩu</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>
