<head>
    <link rel="stylesheet" href="../css/styles-layout.css">
</head>
<main>
    <!-- Login Page -->
    <section id="login" class="container my-5">
        <h2 class="text-center mb-4">Đăng Nhập</h2>
        <div class="row">
            <div class="col-md-6 offset-md-3">
                <div class="card shadow-sm p-4">
                    <form action="/login" method="POST">
                        <div class="mb-3">
                            <label for="loginEmail" class="form-label">Email</label>
                            <input type="text" class="form-control" id="loginEmail" name="email" placeholder="Nhập email">
                            <% if (errors && errors.email) { %>
                                <span class="text-danger"><%= errors.email %></span>
                            <% } %>
                        </div>
                        <div class="mb-3">
                            <label for="loginPassword" class="form-label">Mật khẩu</label>
                            <input type="password" class="form-control" id="loginPassword" name="password" placeholder="Nhập mật khẩu">
                            <% if (errors && errors.password) { %>
                                <span class="text-danger"><%= errors.password %></span>
                            <% } %>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Đăng Nhập</button>
                    </form>
                    
                    <div class="text-center mt-3">
                        <p>Chưa có tài khoản? <a href="/register">Đăng ký ngay</a></p>
                        <p><a href="/forgot-password" class="text-decoration-none">Quên mật khẩu?</a></p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>