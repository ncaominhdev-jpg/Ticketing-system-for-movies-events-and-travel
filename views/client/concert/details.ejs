<head>
    <link rel="stylesheet" href="../../css/styles-layout.css">
    <link rel="stylesheet" href="../../css/client/concert/details.css">
</head>
<!-- Carousel -->
<div id="mainCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="../../img/xem-phim-rap.jpg" class="d-block w-100" alt="Phim">
            <div class="carousel-caption d-none d-md-block">
                <h5>Đặt vé xem phim nhanh chóng</h5>
                <p>Thưởng thức những bộ phim hay nhất.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="../../img/concert.jpg" class="d-block w-100" alt="Sự kiện">
            <div class="carousel-caption d-none d-md-block">
                <h5>Sự kiện nổi bật</h5>
                <p>Không bỏ lỡ các sự kiện hấp dẫn.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="../../img/nha-trang.jpg" class="d-block w-100" alt="Du lịch">
            <div class="carousel-caption d-none d-md-block">
                <h5>Đặt tour du lịch dễ dàng</h5>
                <p>Khám phá những điểm đến lý tưởng.</p>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>
<main class="container my-5 mb-5">
    <!-- Thông tin chi tiết concert -->
    <div class="row">
        <div class="col-md-7">
            <img src="<%= concert.image_url ? '/img/' + concert.image_url : '/img/default-concert.jpg' %>" 
                 class="img-fluid rounded" 
                 alt="Poster Concert">
        </div>
        <div class="col-md-5">
            <h1 class="mb-3"><%= concert.name %></h1>
            <p><strong>Ngày tổ chức: </strong> <%= new Date(concert.event_date).toLocaleDateString('vi-VN') %></p>
            <p><strong>Địa điểm: </strong> <%= concert.location %></p>
            <p><strong>Thời gian: </strong> <%= concert.start_time %></p>
            <p class="mb-4"><%= concert.description %></p>
            <% if (user) { %>
                <a href="/concert/buy-tickets/<%= concert.id %>" class="btn btn-primary">Mua Vé</a>
            <% } else { %>
                <a href="/login" class="btn btn-primary">Đăng nhập để mua vé</a>
            <% } %>
        </div>
    </div>

    <!-- Danh sách nghệ sĩ biểu diễn -->
    <% if (artistImages.length > 0) { %>
        <h2 class="text-center mt-5">Nghệ sĩ biểu diễn</h2>
        <div class="artist-container mt-3">
            <% artistImages.forEach(artist => { %>
                <div class="artist-item">
                    <img src="<%= artist.image_url ? '/img/' + artist.image_url : '/img/default-artist.jpg' %>" 
                         class="img-fluid artist-img rounded-circle" 
                         alt="<%= artist.artist_name %>">
                    <h5><%= artist.artist_name %></h5>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p class="text-center mt-4"><strong>Chưa có thông tin nghệ sĩ biểu diễn.</strong></p>
    <% } %>       

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</main>
