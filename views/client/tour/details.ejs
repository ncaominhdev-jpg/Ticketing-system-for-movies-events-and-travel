<head>
    <link rel="stylesheet" href="../../css/styles-layout.css">
    <link rel="stylesheet" href="../../css/client/concert/details.css">
    <link rel="stylesheet" href="../../css/customer-review.css">
</head>
<!-- Carousel -->
<div id="mainCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="../../img/xem-phim-rap.jpg" class="d-block w-100" alt="Phim">
            <div class="carousel-caption d-none d-md-block">
                <h5>Đặt vé xem phim nhanh chóng</h5>
                <p>Thưởng thức những bộ phim hay nhất.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="../../img/concert.jpg" class="d-block w-100" alt="Sự kiện">
            <div class="carousel-caption d-none d-md-block">
                <h5>Sự kiện nổi bật</h5>
                <p>Không bỏ lỡ các sự kiện hấp dẫn.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="../../img/nha-trang.jpg" class="d-block w-100" alt="Du lịch">
            <div class="carousel-caption d-none d-md-block">
                <h5>Đặt tour du lịch dễ dàng</h5>
                <p>Khám phá những điểm đến lý tưởng.</p>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>
<main class="container my-5">
    <!-- Thông tin chi tiết tour -->
    <div class="row">
        <div class="col-md-7">
            <img src="<%= '../../img/' + tour.image_url %>" class="img-fluid rounded" alt="<%= tour.name %>">
        </div>
        <div class="col-md-5">
            <h1 class="mb-3">Du lịch <%= tour.departure_point %> - <%= tour.destination %>
            </h1>
            <p><strong>Khởi hành:</strong>
                <%= new Date(tour.departure_date).toLocaleDateString('vi-VN') %>
            </p>
            <p><strong>Kết thúc:</strong>
                <%= tour.end_date %>
            </p>
            <p><strong>Thời gian:</strong>
                <%= totalDays %> ngày <%= totalNights %> đêm
            </p>
            <p><strong>Giá:</strong>
                <%= Number(tour.price).toLocaleString("vi-VN").replace(/,/g, '.' ) %> VNĐ/người
            </p>
            <p class="mb-4">
                <%= tour.description %>
            </p>
            <% if (user) { %>
                <a href="/tour/buy-tickets/<%= tour.id %>" class="btn btn-primary">Đặt Tour</a>
            <% } else { %>
                <a href="/login" class="btn btn-primary">Đăng nhập để đặt tour</a>
            <% } %>            
        </div>
    </div>

    <!-- Lịch trình chi tiết -->

    <div class="mt-5">
        <h2 class="mb-4">Lịch Trình Chi Tiết</h2>
        <div class="accordion" id="itineraryAccordion">
            <% if (travelItinerary && travelItinerary.length> 0) { %>
                <% travelItinerary.forEach((item, index)=> { %>
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="day<%= index + 1 %>Heading">
                            <button class="accordion-button <%= index === 0 ? '' : 'collapsed' %>" type="button"
                                data-bs-toggle="collapse" data-bs-target="#day<%= index + 1 %>Content"
                                aria-expanded="<%= index === 0 ? 'true' : 'false' %>"
                                aria-controls="day<%= index + 1 %>Content">
                                Ngày <%= new Date(item.travel_date).toLocaleDateString('vi-VN') %>
                            </button>
                        </h2>
                        <div id="day<%= index + 1 %>Content"
                            class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>"
                            aria-labelledby="day<%= index + 1 %>Heading" data-bs-parent="#itineraryAccordion">
                            <div class="accordion-body">
                                <%- item.itinerary %>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <p>Chưa có lịch trình chi tiết.</p>
                            <% } %>
        </div>
    </div>
</main>